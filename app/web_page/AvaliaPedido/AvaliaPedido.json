      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.pedido ){",
        "\treturn {",
        "\t\t//map pedido variable to expected task contract input",
        "\t\tpedidoInput: {",
        "\t\t\ttempoEsforco1d: $data.pedido.tempoEsforco1d !== undefined ? $data.pedido.tempoEsforco1d : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
