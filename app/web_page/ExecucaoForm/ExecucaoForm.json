      ],
      "exposed" : false
    },
    "submit_errors_list" : {
      "type" : "expression",
      "value" : [
        "if($data.formOutput && $data.formOutput._submitError && $data.formOutput._submitError.explanations){",
        "\tconst liElements = $data.formOutput._submitError.explanations",
        "\t\t.filter(cause => cause !== null)",
        "\t\t.map(cause => \"<li>\" + cause + \"</li>\")",
        "\t\t.join('');",
        "\tif(liElements){",
        "\t\treturn \"<ul>\" + liElements + \"</ul>\";",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "formOutput" : {
      "type" : "expression",
      "value" : [
        "if( $data.pedido ){",
        "\treturn {",
        "\t\t//map pedido variable to expected task contract input",
        "\t\tpedidoInput: {",
        "\t\t\tintervencoes: $data.pedido.intervencoes ? {",
        "\t\t\t\tDataExecucao: $data.pedido.intervencoes.DataExecucao !== undefined ? $data.pedido.intervencoes.DataExecucao : null,",
        "\t\t\t\tdescricao: $data.pedido.intervencoes.descricao !== undefined ? $data.pedido.intervencoes.descricao : null,",
        "\t\t\t\tNumeroHoras: $data.pedido.intervencoes.NumeroHoras !== undefined ? $data.pedido.intervencoes.NumeroHoras : null,",
        "\t\t\t\tFinalizado: $data.pedido.intervencoes.Finalizado !== undefined ? $data.pedido.intervencoes.Finalizado : null",
        "\t\t\t} : null",
        "\t\t}",
        "\t}",
        "}"
      ],
      "exposed" : false
    },
    "context" : {
      "type" : "url",
      "value" : [
        "../API/bpm/userTask/{{taskId}}/context"
      ],
      "exposed" : false
    },
